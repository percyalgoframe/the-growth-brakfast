rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins are marked with a custom auth claim { admin: true } (no phone
    // numbers stored in this public file).
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function fieldsOk() {
      return request.resource.data.keys().hasOnly(
        ['name','email','phone','company','title','linkedin','photoURL','source','createdAt']);
    }

    match /attendees/{id} {

      // Anyone who has completed SMS OTP can read the directory.
      allow read: if request.auth != null;

      // Self sign-up (no OTP): any signed-in visitor (anonymous session) may add
      // an entry with the expected fields. Admins also add via bulk import.
      allow create: if request.auth != null && fieldsOk();

      // Only admins may edit existing entries (e.g. merge from an updated list).
      allow update: if isAdmin() && fieldsOk();

      // Admins can remove entries (upload diff + manual management).
      allow delete: if isAdmin();
    }

    match /checkins/{id} {
      // Attendance log. Admins read; any signed-in (anonymous) attendee may record a
      // visit. Restricted field set; no client deletes.
      allow read: if isAdmin();
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly(['phone','name','date','lastAt','count']);
      allow delete: if false;
    }
  }
}
